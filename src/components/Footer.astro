---
import SiteOptions from "../site.config.mjs"
---

<footer class="mt-20 py-8 border-t border-[#d0cdc6] dark:border-gray-800">
  <div class="flex flex-wrap items-center justify-between gap-4">
    <nav class="flex items-center gap-6 text-sm">
      {
        SiteOptions.showCategoriesLinkOnFooter && (
          <a href="/categories" data-i18n="footer_categories" class="text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors font-medium">
            التصنيفات
          </a>
        )
      }
      {
        SiteOptions.showTagsLinkOnFooter && (
          <a href="/tags" data-i18n="footer_tags" class="text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors font-medium">
            الوسوم
          </a>
        )
      }
    </nav>
    <p data-i18n="copyright" class="text-sm text-gray-400 dark:text-gray-500">
      © 2026 عبد الرحمان هلال. جميع الحقوق محفوظة.
    </p>
  </div>
</footer>

---
import { type CollectionEntry } from "astro:content"
import SiteOptions from "../site.config.mjs"
import { getCategoryAr } from "../utils/categories"

export interface Props {
  post: CollectionEntry<"article">
}

const { post } = Astro.props
const { title, description, thumb, category } = post.data
const postLang = post.data.lang ?? "en"
const categoryAr = getCategoryAr(category)
---

<article data-post-lang={postLang} class="flex flex-col group">
  {
    SiteOptions.showThumbnailOnFeaturedPosts && thumb && (
      <a href={`/article/${post.slug}`} class="block mb-4 overflow-hidden">
        <img
          src={thumb}
          alt={title}
          class="w-full h-48 object-cover transition-opacity group-hover:opacity-90"
          loading="lazy"
        />
      </a>
    )
  }
  {
    category && (
      <span data-text-ar={categoryAr} data-text-en={category} class="text-[11px] font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-2 block">
        {categoryAr}
      </span>
    )
  }
  <h3 class="text-lg font-bold leading-snug mb-2 text-gray-900 dark:text-slate-100">
    <a href={`/article/${post.slug}`} class="group-hover:underline decoration-1 underline-offset-2">
      {title}
    </a>
  </h3>
  <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed mb-4 flex-grow line-clamp-3">
    {description}
  </p>
  {
    SiteOptions.showReadMoreLinkOnFeaturedPosts && (
      <a
        href={`/article/${post.slug}`}
        data-i18n="read_more"
        class="text-[11px] font-bold uppercase tracking-[0.1em] text-gray-900 dark:text-white hover:opacity-60 transition-opacity mt-auto self-start"
      >
        اقرأ المزيد
      </a>
    )
  }
</article>

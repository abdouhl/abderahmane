---
import { type CollectionEntry } from "astro:content"

export interface Props {
  post: CollectionEntry<"article">
  showCategory?: boolean
}

const { post, showCategory = true } = Astro.props
const { title, pubDate, category, description, thumb } = post.data

const dateAr = new Intl.DateTimeFormat("ar", {
  year: "numeric", month: "long", day: "numeric",
}).format(pubDate)

const dateEn = new Intl.DateTimeFormat("en-US", {
  year: "numeric", month: "short", day: "numeric",
}).format(pubDate)
---

<li class="flex items-start gap-6 py-7 border-b border-[#d0cdc6] dark:border-gray-800 group">
  {
    thumb && (
      <a href={`/article/${post.slug}`} class="shrink-0 hidden sm:block overflow-hidden">
        <img
          src={thumb}
          alt={title}
          class="w-[200px] h-[135px] object-cover"
          loading="lazy"
        />
      </a>
    )
  }
  <div class="flex-1 min-w-0">
    <p class="text-xs text-gray-400 dark:text-gray-500 mb-2">
      <span data-date-ar={dateAr} data-date-en={dateEn}>{dateAr}</span>
      {showCategory && category && <> &nbsp;·&nbsp; {category}</>}
    </p>
    <h2 class="text-xl font-bold leading-snug mb-2 text-gray-900 dark:text-slate-100">
      <a href={`/article/${post.slug}`} class="group-hover:underline decoration-1 underline-offset-2">
        {title}
      </a>
    </h2>
    <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed line-clamp-2 mb-4">
      {description}
    </p>
    <a
      href={`/article/${post.slug}`}
      data-i18n="read_more"
      class="text-[11px] font-bold uppercase tracking-[0.1em] text-gray-900 dark:text-white hover:opacity-60 transition-opacity"
    >
      اقرأ المزيد
    </a>
  </div>
</li>

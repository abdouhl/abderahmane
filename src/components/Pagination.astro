---
import SiteOptions from "../site.config.mjs"
export interface Props {
  page: {
    data: any[]
    url: { current: string; next?: string; prev?: string }
    currentPage: number
    lastPage: number
    size: number
    total: number
  }
}

const { page } = Astro.props
const from = (page.currentPage - 1) * page.size + 1
const to = Math.min(page.currentPage * page.size, page.total)

const infoAr = `عرض ${from}–${to} من أصل ${page.total} مقال`
const infoEn = `Showing ${from}–${to} of ${page.total} posts`
---

<nav class="flex justify-center items-center gap-2 mt-14" aria-label="Pagination">
  {
    page.url.prev ? (
      <a
        href={page.url.prev}
        data-i18n="prev_page"
        class="px-4 py-2 text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 border border-[#d0cdc6] dark:border-gray-700 hover:border-gray-400 transition-colors"
      >
        ← السابق
      </a>
    ) : (
      <span
        data-i18n="prev_page"
        class="px-4 py-2 text-sm font-medium text-gray-300 dark:text-gray-700 border border-[#d0cdc6] dark:border-gray-800 cursor-not-allowed"
      >
        ← السابق
      </span>
    )
  }

  <div class="flex items-center gap-1">
    {
      Array.from({ length: page.lastPage }, (_, i) => i + 1).map((n) => {
        const isCurrent = n === page.currentPage
        const url = n === 1 ? "/blog/" : `/blog/${n}/`
        return isCurrent ? (
          <span class="px-3 py-2 text-sm font-medium bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900" aria-current="page">
            {n}
          </span>
        ) : (
          <a href={url} class="px-3 py-2 text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 hover:bg-black/5 dark:hover:bg-white/10 transition-colors">
            {n}
          </a>
        )
      })
    }
  </div>

  {
    page.url.next ? (
      <a
        href={page.url.next}
        data-i18n="next_page"
        class="px-4 py-2 text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 border border-[#d0cdc6] dark:border-gray-700 hover:border-gray-400 transition-colors"
      >
        التالي →
      </a>
    ) : (
      <span
        data-i18n="next_page"
        class="px-4 py-2 text-sm font-medium text-gray-300 dark:text-gray-700 border border-[#d0cdc6] dark:border-gray-800 cursor-not-allowed"
      >
        التالي →
      </span>
    )
  }
</nav>

<div
  data-text-ar={infoAr}
  data-text-en={infoEn}
  class="text-center mt-4 text-sm text-gray-400 dark:text-gray-500"
>
  {infoAr}
</div>

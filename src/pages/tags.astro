---
import { getCollection } from "astro:content"
import BlogLayout from "../layouts/BlogLayout.astro"
import Header from "../components/Header.astro"
import Footer from "../components/Footer.astro"
import SiteOptions from "../site.config.mjs"

const allPosts = await getCollection("article")
const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags))].sort()
const tagCounts = allTags.map((tag) => ({
  name: tag,
  count: allPosts.filter((post) => post.data.tags.includes(tag)).length,
}))
---

<BlogLayout title={`الوسوم — ${SiteOptions.siteTitle}`} description="تصفح المقالات حسب الوسوم">
  <Header slot="hero" />

  <div class="pt-10 pb-6 border-b border-[#d0cdc6] dark:border-gray-800 mb-12">
    <h1 data-i18n="all_tags" class="text-3xl font-bold tracking-tight text-gray-900 dark:text-slate-100">
      جميع الوسوم
    </h1>
    <p data-i18n="explore_tag" class="mt-2 text-gray-500 dark:text-gray-400 text-sm">
      استكشف المقالات حسب الوسم
    </p>
  </div>

  <section>
    <div class="flex flex-wrap gap-3">
      {tagCounts.map(({ name, count }) => (
        <a
          href={`/tag/${name.toLowerCase().replace(/\s+/g, "-")}`}
          class="flex items-center gap-2 px-4 py-2 border border-[#d0cdc6] dark:border-gray-700 hover:border-gray-400 dark:hover:border-gray-500 transition-colors group"
        >
          <span class="font-medium text-gray-900 dark:text-slate-100 capitalize group-hover:underline decoration-1">
            {name}
          </span>
          <span class="text-xs text-gray-400 dark:text-gray-500 tabular-nums">({count})</span>
        </a>
      ))}
    </div>
  </section>

  <div class="mt-14 text-center">
    <a href="/" data-i18n="back_home" class="text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
      العودة إلى الرئيسية
    </a>
  </div>

  <Footer />
</BlogLayout>

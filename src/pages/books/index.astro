---
import { getCollection } from "astro:content"
import { Image } from "astro:assets"
import BlogLayout from "../../layouts/BlogLayout.astro"
import Header from "../../components/Header.astro"
import Footer from "../../components/Footer.astro"
import SiteOptions from "../../site.config.mjs"

const books = (await getCollection("books")).sort((a, b) => a.data.number - b.data.number)

const pageTitle = `ملخصات الكتب | ${SiteOptions.siteTitle}`
const pageDescription = "ملخصات قصيرة لأفكار كتب قرأتها."
---

<BlogLayout title={pageTitle} description={pageDescription}>
  <Header slot="hero" />

  <div class="pt-10 pb-6 border-b border-[#d0cdc6] dark:border-gray-800 mb-12">
    <h1 data-i18n="all_books" class="text-3xl font-bold tracking-tight text-gray-900 dark:text-slate-100">
      ملخصات الكتب
    </h1>
    <p data-i18n="explore_books" class="mt-2 text-gray-500 dark:text-gray-400 text-sm">
      ملخصات قصيرة لأفكار كتب قرأتها.
    </p>
  </div>

  {books.length === 0 ? (
    <p class="text-sm text-gray-500 dark:text-gray-400 py-10">لا توجد ملخصات بعد.</p>
  ) : (
    <ul>
      {books.map((book) => (
        <li class="flex items-start gap-6 py-8 border-b border-[#d0cdc6] dark:border-gray-800 group">
          {book.data.cover ? (
            <a href={`/books/${book.slug}`} class="hidden sm:block shrink-0 w-16 h-24 overflow-hidden border border-[#d0cdc6] dark:border-gray-800">
              <Image src={book.data.cover} alt={book.data.title} width={128} height={192} class="w-full h-full object-cover" />
            </a>
          ) : (
            <span class="hidden sm:block shrink-0 text-3xl font-black text-gray-200 dark:text-gray-800 tabular-nums leading-none pt-1">
              {String(book.data.number).padStart(2, "0")}
            </span>
          )}
          <div class="flex-1 min-w-0">
            <h2 class="text-2xl sm:text-3xl font-bold leading-snug mb-1 text-gray-900 dark:text-slate-100">
              <a href={`/books/${book.slug}`} class="group-hover:underline decoration-1 underline-offset-4">
                {book.data.title}
              </a>
            </h2>
            {book.data.arabicTitle && (
              <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">{book.data.arabicTitle}</p>
            )}
            <p class="text-xs font-semibold uppercase tracking-[0.1em] text-gray-400 dark:text-gray-500 mb-3">
              {book.data.author}
            </p>
            <p class="text-sm sm:text-base text-gray-500 dark:text-gray-400 leading-relaxed mb-4 max-w-xl">
              {book.data.feedSummary}
            </p>
            <a
              href={`/books/${book.slug}`}
              class="inline-flex items-center gap-1.5 text-[11px] font-bold uppercase tracking-[0.1em] text-gray-900 dark:text-white hover:opacity-60 transition-opacity"
            >
              <span data-i18n="read_more">اقرأ المزيد</span>
            </a>
          </div>
        </li>
      ))}
    </ul>
  )}

  <div class="mt-14 text-center">
    <a href="/" data-i18n="back_home" class="text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
      العودة إلى الرئيسية
    </a>
  </div>

  <Footer />
</BlogLayout>

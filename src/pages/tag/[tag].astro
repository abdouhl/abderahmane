---
import { type CollectionEntry, getCollection } from "astro:content"
import BlogLayout from "../../layouts/BlogLayout.astro"
import Header from "../../components/Header.astro"
import Footer from "../../components/Footer.astro"
import PostCard from "../../components/PostCard.astro"
import SiteOptions from "../../site.config.mjs"

export async function getStaticPaths() {
  const allPosts = await getCollection("article")
  const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags))]

  return allTags.map((tag) => ({
    params: { tag: tag.toLowerCase().replace(/\s+/g, "-") },
    props: {
      tag,
      posts: allPosts
        .filter((post) =>
          post.data.tags.some(
            (postTag) =>
              postTag.toLowerCase().replace(/\s+/g, "-") === tag.toLowerCase().replace(/\s+/g, "-")
          )
        )
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }))
}

type Props = {
  tag: string
  posts: CollectionEntry<"article">[]
}

const { tag, posts } = Astro.props
const countLabel = `${posts.length} ${posts.length === 1 ? "article" : "articles"}`
---

<BlogLayout title={`${tag} — ${SiteOptions.siteTitle}`} description={`Articles tagged ${tag}`}>
  <Header slot="hero" />

  <div class="pt-10 pb-6 border-b border-[#d0cdc6] dark:border-gray-800 mb-12">
    <p class="text-[11px] font-bold uppercase tracking-[0.12em] text-gray-400 dark:text-gray-500 mb-2">
      Tag
    </p>
    <h1 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-slate-100 capitalize">
      {tag}
    </h1>
    <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">{countLabel}</p>
  </div>

  <section>
    {
      posts.length > 0 ? (
        <ul>
          {posts.map((post) => (
            <PostCard post={post} showCategory={true} />
          ))}
        </ul>
      ) : (
        <div class="py-12 text-center">
          <p class="text-gray-500 dark:text-gray-400">{SiteOptions.labels.noArticlesFound}</p>
        </div>
      )
    }
  </section>

  <div class="mt-14 flex justify-center gap-8">
    <a href="/tags" class="text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
      {SiteOptions.labels.allTags}
    </a>
    <a href="/" class="text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
      {SiteOptions.labels.backToHome}
    </a>
  </div>

  <Footer />
</BlogLayout>

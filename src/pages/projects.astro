---
import BlogLayout from "../layouts/BlogLayout.astro"
import Header from "../components/Header.astro"
import Footer from "../components/Footer.astro"
import SiteOptions from "../site.config.mjs"

const projects = [
  {
    name: "xarticl.es",
    url: "https://xarticl.es",
    descAr: "دليل منتقى لأفضل المقالات الطويلة على X.",
    descEn: "A curated directory of the best long-form articles on X.",
  },
  {
    name: "elhellal.com",
    url: "https://elhellal.com",
    descAr: "دليل منتقى لأفضل المقالات العربية على الإنترنت.",
    descEn: "A curated directory of the best Arabic articles on the internet.",
  },
]
---

<BlogLayout title={`المشاريع — ${SiteOptions.siteTitle}`} description="مشاريع وأعمال شخصية">
  <Header slot="hero" />

  <div class="pt-10 pb-6 border-b border-[#d0cdc6] dark:border-gray-800 mb-12">
    <h1 data-i18n="all_projects" class="text-3xl font-bold tracking-tight text-gray-900 dark:text-slate-100">
      المشاريع
    </h1>
    <p data-i18n="explore_projects" class="mt-2 text-gray-500 dark:text-gray-400 text-sm">
      مشاريع وأعمال شخصية
    </p>
  </div>

  <section>
    <ul>
      {projects.map(({ name, url, descAr, descEn }, i) => (
        <li class="flex items-start gap-6 py-8 border-b border-[#d0cdc6] dark:border-gray-800 group">
          <span class="hidden sm:block shrink-0 text-3xl font-black text-gray-200 dark:text-gray-800 tabular-nums leading-none pt-1">
            {String(i + 1).padStart(2, "0")}
          </span>
          <div class="flex-1 min-w-0">
            <h2 class="text-2xl sm:text-3xl font-bold leading-snug mb-2 text-gray-900 dark:text-slate-100">
              <a href={url} target="_blank" rel="noopener noreferrer" class="group-hover:underline decoration-1 underline-offset-4">
                {name}
              </a>
            </h2>
            <p data-text-ar={descAr} data-text-en={descEn} class="text-sm sm:text-base text-gray-500 dark:text-gray-400 leading-relaxed mb-4 max-w-xl">
              {descAr}
            </p>
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-[11px] font-bold uppercase tracking-[0.1em] text-gray-900 dark:text-white hover:opacity-60 transition-opacity"
            >
              <span data-i18n="visit_site">زيارة الموقع</span>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3 h-3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
            </a>
          </div>
        </li>
      ))}
    </ul>
  </section>

  <div class="mt-14 text-center">
    <a href="/" data-i18n="back_home" class="text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
      العودة إلى الرئيسية
    </a>
  </div>

  <Footer />
</BlogLayout>

---
import { type CollectionEntry, getCollection } from "astro:content"
import BlogLayout from "../../layouts/BlogLayout.astro"
import Header from "../../components/Header.astro"
import Footer from "../../components/Footer.astro"
import PostCard from "../../components/PostCard.astro"
import SiteOptions from "../../site.config.mjs"

export async function getStaticPaths() {
  const allPosts = await getCollection("article")
  const allAuthors = [...new Set(allPosts.map((post) => post.data.author))]

  return allAuthors.map((author) => ({
    params: { author: author.toLowerCase().replace(/\s+/g, "-") },
    props: {
      author,
      posts: allPosts
        .filter((post) => post.data.author === author)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }))
}

type Props = {
  author: string
  posts: CollectionEntry<"article">[]
}

const { author, posts } = Astro.props
const countLabel = `${posts.length} ${posts.length === 1 ? "article" : "articles"}`
---

<BlogLayout title={`${author} — ${SiteOptions.siteTitle}`} description={`Articles by ${author}`}>
  <Header slot="hero" />

  <div class="pt-10 pb-6 border-b border-[#d0cdc6] dark:border-gray-800 mb-12">
    <p class="text-[11px] font-bold uppercase tracking-[0.12em] text-gray-400 dark:text-gray-500 mb-2">
      Author
    </p>
    <h1 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-slate-100">
      {author}
    </h1>
    <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">{countLabel}</p>
  </div>

  <section>
    {
      posts.length > 0 ? (
        <ul>
          {posts.map((post) => (
            <PostCard post={post} showCategory={true} />
          ))}
        </ul>
      ) : (
        <div class="py-12 text-center">
          <p class="text-gray-500 dark:text-gray-400">{SiteOptions.labels.noArticlesFound}</p>
        </div>
      )
    }
  </section>

  <div class="mt-14 flex justify-center gap-8">
    <a href="/authors" class="text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
      {SiteOptions.labels.allAuthors}
    </a>
    <a href="/" class="text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
      {SiteOptions.labels.backToHome}
    </a>
  </div>

  <Footer />
</BlogLayout>

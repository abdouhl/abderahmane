---
import { getCollection } from "astro:content"
import { Image } from "astro:assets"
import BlogLayout from "../../layouts/BlogLayout.astro"
import Header from "../../components/Header.astro"
import Footer from "../../components/Footer.astro"
import SiteOptions from "../../site.config.mjs"

const posts = (await getCollection("taammulat")).sort((a, b) => b.data.number - a.data.number)

const pageTitle = `تأملات | ${SiteOptions.siteTitle}`
const pageDescription = "تأملات قصيرة ومتفرقة في الحياة والطموح والسلوك الإنساني."
---

<BlogLayout title={pageTitle} description={pageDescription}>
  <Header slot="hero" />

  <div class="mt-10 mb-6 border-b border-[#d0cdc6] dark:border-gray-800 pb-4">
    <h1 class="text-[11px] font-bold uppercase tracking-[0.15em] text-gray-400 dark:text-gray-500">
      تأملات
    </h1>
    <p class="mt-3 text-sm text-gray-500 dark:text-gray-400 max-w-xl">
      تأملات قصيرة، منفصلة عن المقالات، في الحياة والطموح والسلوك الإنساني.
    </p>
  </div>

  {posts.length === 0 ? (
    <p class="text-sm text-gray-500 dark:text-gray-400 py-10">لا توجد تأملات بعد.</p>
  ) : (
    <ul dir="rtl" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 sm:gap-4 py-2">
      {posts.map((post) => (
        <li>
          <a
            href={`/taammulat/${post.data.number}`}
            class="block aspect-[4/5] overflow-hidden border border-[#d0cdc6] dark:border-gray-800 hover:opacity-85 transition-opacity"
          >
            <Image
              src={post.data.image}
              alt={post.data.title}
              width={400}
              height={500}
              class="w-full h-full object-cover"
            />
          </a>
        </li>
      ))}
    </ul>
  )}

  <Footer />
</BlogLayout>

---
import { type CollectionEntry, getCollection } from "astro:content"
import { Image } from "astro:assets"
import BlogLayout from "../../layouts/BlogLayout.astro"
import Header from "../../components/Header.astro"
import Footer from "../../components/Footer.astro"

export async function getStaticPaths() {
  const posts = await getCollection("taammulat")
  return posts.map((post) => ({
    params: { number: String(post.data.number) },
    props: post,
  }))
}

type Props = CollectionEntry<"taammulat">

const post = Astro.props
const { title, date, number, image } = post.data
const { Content } = await post.render()

const allPosts = (await getCollection("taammulat")).sort((a, b) => a.data.number - b.data.number)
const currentIndex = allPosts.findIndex((p) => p.data.number === number)
const prevPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null
const nextPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null

const dateAr = new Intl.DateTimeFormat("ar", {
  year: "numeric", month: "long", day: "numeric",
}).format(date)
---

<BlogLayout title={`تأملات #${number}: ${title}`} description={title} image={`/og/taammulat/${number}.png`} type="article">
  <Header slot="hero" />

  <div class="pt-10 pb-6 border-b border-[#d0cdc6] dark:border-gray-800">
    <a
      href="/taammulat"
      class="text-[11px] font-bold uppercase tracking-[0.12em] text-gray-400 dark:text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 transition-colors mb-4 block"
    >
      تأملات #{number}
    </a>
    <h1 class="text-2xl md:text-3xl font-bold tracking-tight mb-3 text-gray-900 dark:text-slate-50 leading-tight">
      {title}
    </h1>
    <p class="text-sm text-gray-500 dark:text-gray-400">{dateAr}</p>
  </div>

  <div class="mt-10 max-w-[420px] mx-auto">
    <Image src={image} alt={title} class="w-full h-auto border border-[#d0cdc6] dark:border-gray-800" />
  </div>

  <article
    class="mt-10 prose prose-lg max-w-[640px] mx-auto
      prose-headings:hidden
      prose-p:text-gray-700 dark:prose-p:text-slate-300
      prose-strong:text-gray-900 dark:prose-strong:text-slate-100"
  >
    <Content />
  </article>

  <nav class="mt-14 flex items-center justify-between border-t border-[#d0cdc6] dark:border-gray-800 pt-6 text-sm">
    {prevPost ? (
      <a href={`/taammulat/${prevPost.data.number}`} class="text-gray-600 dark:text-gray-300 hover:underline">
        → تأملات #{prevPost.data.number}
      </a>
    ) : <span />}
    {nextPost ? (
      <a href={`/taammulat/${nextPost.data.number}`} class="text-gray-600 dark:text-gray-300 hover:underline">
        تأملات #{nextPost.data.number} ←
      </a>
    ) : <span />}
  </nav>

  <Footer />
</BlogLayout>

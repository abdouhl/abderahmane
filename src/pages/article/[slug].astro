---
import { type CollectionEntry, getCollection } from "astro:content"
import BlogLayout from "../../layouts/BlogLayout.astro"
import Header from "../../components/Header.astro"
import Footer from "../../components/Footer.astro"
import FeaturedCard from "../../components/FeaturedCard.astro"
import SiteOptions from "../../site.config.mjs"

export async function getStaticPaths() {
  const posts = await getCollection("article")
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }))
}

type Props = CollectionEntry<"article">

const post = Astro.props
const { title, pubDate, category, description, author, tags, large } = post.data
const { Content } = await post.render()

const allPosts = await getCollection("article")
const postLang = post.data.lang ?? "en"
const postTags = new Set(post.data.tags ?? [])

const similarPosts = allPosts
  .filter((p) => p.slug !== post.slug && (p.data.lang ?? "en") === postLang)
  .map((p) => {
    const sharedTags = (p.data.tags ?? []).filter((t) => postTags.has(t)).length
    const sameCategory = p.data.category === post.data.category ? 1 : 0
    return { post: p, score: sharedTags * 2 + sameCategory }
  })
  .sort((a, b) => b.score - a.score || b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf())
  .slice(0, 3)
  .map((entry) => entry.post)

const dateAr = new Intl.DateTimeFormat("ar", {
  year: "numeric", month: "long", day: "numeric",
}).format(pubDate)

const dateEn = new Intl.DateTimeFormat("en-US", {
  year: "numeric", month: "long", day: "numeric",
}).format(pubDate)
---

<BlogLayout title={title} description={description} image={`/og/articles/${post.slug}.png`} pubDate={pubDate} articleAuthor={author} type="article">
  <Header slot="hero" />

  <div class="pt-10 pb-6 border-b border-[#d0cdc6] dark:border-gray-800">
    {category && (
      <a
        href={`/category/${category.toLowerCase().replace(/\s+/g, "-")}`}
        class="text-[11px] font-bold uppercase tracking-[0.12em] text-gray-400 dark:text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 transition-colors mb-4 block"
      >
        {category}
      </a>
    )}

    <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-5 text-gray-900 dark:text-slate-50 leading-tight">
      {title}
    </h1>

    <div class="flex flex-wrap items-center gap-3 text-sm text-gray-500 dark:text-gray-400">
      <a
        href={`/author/${author.toLowerCase().replace(/\s+/g, "-")}`}
        class="font-semibold text-gray-700 dark:text-gray-300 hover:underline"
      >
        {author}
      </a>
      <span class="text-gray-300 dark:text-gray-600">·</span>
      <span data-date-ar={dateAr} data-date-en={dateEn}>{dateAr}</span>
    </div>

    {tags && tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-4">
        {tags.map((tag) => (
          <a
            href={`/tag/${tag.toLowerCase().replace(/\s+/g, "-")}`}
            class="text-xs text-gray-500 dark:text-gray-400 border border-[#d0cdc6] dark:border-gray-700 px-2 py-1 hover:border-gray-400 dark:hover:border-gray-500 hover:text-gray-700 dark:hover:text-gray-300 transition-colors"
          >
            {tag}
          </a>
        ))}
      </div>
    )}
  </div>

  <article
    class="mt-10 prose prose-lg max-w-none
      prose-headings:font-bold prose-headings:text-gray-900 dark:prose-headings:text-slate-100
      prose-p:text-gray-700 dark:prose-p:text-slate-300
      prose-a:text-gray-900 dark:prose-a:text-slate-100 prose-a:underline prose-a:decoration-gray-300 dark:prose-a:decoration-gray-600
      prose-strong:text-gray-900 dark:prose-strong:text-slate-100
      prose-code:text-slate-700 dark:prose-code:text-slate-200
      prose-pre:bg-gray-50 dark:prose-pre:bg-slate-800
      prose-blockquote:border-gray-300 dark:prose-blockquote:border-gray-600
      prose-blockquote:text-gray-600 dark:prose-blockquote:text-gray-400
      prose-img:rounded-none"
  >
    {large && (
      <div class="mb-8 -mx-4 sm:mx-0">
        <img src={large} alt={title} class="w-full h-auto" />
      </div>
    )}
    <Content />
  </article>

  {SiteOptions.showSimilarPosts && similarPosts.length > 0 && (
    <>
      <hr class="border-t border-[#d0cdc6] dark:border-gray-800 my-14" />
      <section>
        <h2 data-i18n="you_might_like" class="text-[11px] font-bold uppercase tracking-[0.15em] text-gray-400 dark:text-gray-500 mb-8">
          قد يعجبك أيضاً
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
          {similarPosts.map((p) => <FeaturedCard post={p} />)}
        </div>
      </section>
    </>
  )}

  <Footer />
</BlogLayout>

---
import { getCollection } from "astro:content"
import type { GetStaticPaths } from "astro"
import BlogLayout from "../../layouts/BlogLayout.astro"
import Header from "../../components/Header.astro"
import Footer from "../../components/Footer.astro"
import PostCard from "../../components/PostCard.astro"
import Pagination from "../../components/Pagination.astro"
import SiteOptions from "../../site.config.mjs"

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection("article")
  const sortedPosts = allPosts.sort(
    (a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
  )
  return paginate(sortedPosts, { pageSize: SiteOptions.numberOfBlogPostsPerPage || 8 })
}) satisfies GetStaticPaths

const { page } = Astro.props
const pageTitle = page.currentPage === 1
  ? SiteOptions.siteTitle
  : `الأرشيف - صفحة ${page.currentPage} | ${SiteOptions.siteTitle}`
---

<BlogLayout title={pageTitle}>
  <Header slot="hero" />

  <div class="mt-10 mb-6 border-b border-[#d0cdc6] dark:border-gray-800 pb-4">
    <h1 data-i18n="nav_archive" class="text-[11px] font-bold uppercase tracking-[0.15em] text-gray-400 dark:text-gray-500">
      الأرشيف
    </h1>
  </div>

  <ul>
    {page.data.map((post) => <PostCard post={post} showCategory={true} />)}
  </ul>

  <Pagination page={page} />

  <Footer />
</BlogLayout>
